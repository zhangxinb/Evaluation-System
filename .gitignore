# Professional Image Evaluation System - Git Ignore File
# =====================================================

# ==================
# LARGE MODEL FILES
# ==================
# Pre-trained models (too large for Git)
models/*.pt
models/*.pth
models/*.ckpt
models/*.bin
models/*.h5
models/*.pb
models/*.onnx
models/*.tflite
models/*.safetensors

# But allow documentation and structure files in models/
!models/README.md
!models/.gitkeep
!models/**/README.md
!models/**/.gitkeep


# DeepFace models cache
.deepface/
~/.deepface/

# ==================
# PYTHON CACHE FILES
# ==================
__pycache__/
*.py[cod]
*$py.class
*.so

